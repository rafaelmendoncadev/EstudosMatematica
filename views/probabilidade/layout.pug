doctype html
html.light(lang='pt-BR')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0, viewport-fit=cover')
    title ProbabilidadeEdu - Probabilidade
    script(src='https://cdn.tailwindcss.com?plugins=forms,container-queries')
    link(href='https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap' rel='stylesheet')
    link(href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap' rel='stylesheet')
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css' crossorigin='anonymous')
    script(src='https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js' crossorigin='anonymous' defer)
    script(src='https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js' crossorigin='anonymous' defer onload='renderMathInElement(document.body);')
    script.
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-background": "#191c1e",
              "outline-variant": "#c3c6d7",
              "on-primary-fixed": "#00174b",
              "on-secondary-fixed": "#002109",
              "on-tertiary-fixed": "#281800",
              "inverse-on-surface": "#eff1f3",
              "secondary-container": "#7cf994",
              "surface-container-highest": "#e0e3e5",
              "secondary-fixed-dim": "#62df7d",
              "tertiary-fixed": "#ffddb0",
              "on-tertiary-fixed-variant": "#614000",
              "background": "#f7f9fb",
              "secondary": "#006e2d",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "tertiary-fixed-dim": "#ffba46",
              "on-tertiary": "#ffffff",
              "error": "#ba1a1a",
              "surface-bright": "#f7f9fb",
              "on-primary": "#ffffff",
              "inverse-primary": "#b4c5ff",
              "surface-container-lowest": "#ffffff",
              "primary-fixed-dim": "#b4c5ff",
              "surface-container": "#eceef0",
              "inverse-surface": "#2d3133",
              "primary-container": "#2563eb",
              "tertiary-container": "#946400",
              "on-primary-fixed-variant": "#003ea8",
              "secondary-fixed": "#7ffc97",
              "on-secondary": "#ffffff",
              "primary-fixed": "#dbe1ff",
              "surface-container-low": "#f2f4f6",
              "surface-dim": "#d8dadc",
              "primary": "#004ac6",
              "on-surface-variant": "#434655",
              "on-tertiary-container": "#ffeedc",
              "outline": "#737686",
              "surface-tint": "#0053db",
              "on-secondary-container": "#007230",
              "on-surface": "#191c1e",
              "surface": "#f7f9fb",
              "on-error-container": "#93000a",
              "on-secondary-fixed-variant": "#005320",
              "on-primary-container": "#eeefff",
              "surface-variant": "#e0e3e5",
              "surface-container-high": "#e6e8ea",
              "tertiary": "#744e00"
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px"
            },
            spacing: {
              "stack-md": "16px",
              "container-max": "1280px",
              "margin-desktop": "40px",
              "stack-lg": "32px",
              "stack-sm": "8px",
              gutter: "24px",
              "margin-mobile": "16px"
            },
            fontFamily: {
              "label-md": ["Inter", "sans-serif"],
              "headline-md": ["Inter", "sans-serif"],
              "headline-lg": ["Inter", "sans-serif"],
              "body-lg": ["Inter", "sans-serif"],
              "body-md": ["Inter", "sans-serif"],
              "display-lg": ["Inter", "sans-serif"],
              "headline-lg-mobile": ["Inter", "sans-serif"],
              "label-sm": ["Inter", "sans-serif"]
            },
            fontSize: {
              "label-md": ["14px", { lineHeight: "20px", letterSpacing: "0.01em", fontWeight: "500" }],
              "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }],
              "headline-lg": ["32px", { lineHeight: "40px", fontWeight: "600" }],
              "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
              "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
              "display-lg": ["48px", { lineHeight: "56px", letterSpacing: "-0.02em", fontWeight: "700" }],
              "headline-lg-mobile": ["24px", { lineHeight: "32px", fontWeight: "600" }],
              "label-sm": ["12px", { lineHeight: "16px", letterSpacing: "0.05em", fontWeight: "600" }]
            }
          }
        }
      };
    style.
      body { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      .details-expand[open] summary ~ * {
        animation: slideDown 0.3s ease-in-out;
      }
      @keyframes slideDown {
        0% { opacity: 0; transform: translateY(-10px); }
        100% { opacity: 1; transform: translateY(0); }
      }
      .blur-backdrop { backdrop-filter: blur(4px); }
      .quiz-option input:checked + span {
        color: #004ac6;
        font-weight: 600;
      }
      .quiz-option:has(input:checked) {
        border-color: #004ac6;
        background-color: rgba(37, 99, 235, 0.05);
      }
      details.details-expand summary::-webkit-details-marker { display: none; }
      .math-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .math-scroll .katex-display { margin: 0.5em 0; }
      @media (max-width: 767px) {
        .study-card { padding: 16px; }
        .section-anchor { scroll-margin-top: 88px; }
        .quiz-option { min-height: 48px; }
        details.details-expand summary { gap: 8px; align-items: flex-start; }
        #score-display { font-size: 2.25rem; line-height: 2.5rem; }
        body {
          padding-bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px));
        }
        #bottom-nav {
          padding-bottom: env(safe-area-inset-bottom, 0px);
        }
      }
      @media (min-width: 768px) {
        .section-anchor { scroll-margin-top: 100px; }
      }
  body(class='bg-background text-on-background font-body-md text-body-md antialiased pt-14 md:pt-[72px] pb-[4.5rem] md:pb-0')
    header(class='fixed top-0 left-0 w-full h-14 md:h-[72px] z-50 flex justify-between items-center px-4 md:px-margin-desktop bg-surface/95 backdrop-blur-md border-b border-outline-variant shadow-sm')
      .flex.items-center.gap-2(class='md:gap-gutter min-w-0')
        h1(class='text-lg sm:text-headline-md font-headline-md font-bold text-primary truncate') ProbabilidadeEdu
        nav(class='hidden md:flex gap-stack-lg' id='main-nav')
          a.nav-link(href='#teoria' data-section='teoria' class='text-primary border-b-2 border-primary pb-1 text-label-md font-label-md') Teoria
          a.nav-link(href='#questoes' data-section='questoes' class='text-on-surface-variant text-label-md font-label-md hover:text-primary transition-colors') Questões Resolvidas
          a.nav-link(href='#simulado' data-section='simulado' class='text-on-surface-variant text-label-md font-label-md hover:text-primary transition-colors') Simulado
          a.nav-link(href='#exercicios' id='nav-exercicios' data-section='exercicios' class='text-on-surface-variant text-label-md font-label-md hover:text-primary transition-colors flex items-center gap-1')
            span Exercícios do Quadro
            span.material-symbols-outlined.hidden(class='text-[16px]' id='nav-lock-icon') lock
      button#mobile-menu-btn(type='button' aria-label='Abrir menu' aria-expanded='false' class='md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-surface-container text-on-surface')
        span.material-symbols-outlined menu
      #nav-progress.absolute.bottom-0.left-0.w-full.h-1.bg-surface-variant
        #nav-progress-bar.h-full.bg-primary.transition-all.duration-300(style='width: 25%')
    #mobile-menu(class='md:hidden hidden fixed top-14 left-0 right-0 z-40 bg-surface border-b border-outline-variant shadow-lg')
      nav(class='flex flex-col py-2' id='mobile-nav')
        a.nav-link(href='#teoria' data-section='teoria' class='px-4 py-3 text-label-md font-label-md text-primary bg-primary-fixed/30 border-l-4 border-primary') Teoria
        a.nav-link(href='#questoes' data-section='questoes' class='px-4 py-3 text-label-md font-label-md text-on-surface-variant hover:bg-surface-container-low') Questões Resolvidas
        a.nav-link(href='#simulado' data-section='simulado' class='px-4 py-3 text-label-md font-label-md text-on-surface-variant hover:bg-surface-container-low') Simulado
        a.nav-link(href='#exercicios' data-section='exercicios' class='px-4 py-3 text-label-md font-label-md text-on-surface-variant hover:bg-surface-container-low flex items-center gap-2')
          span Exercícios do Quadro
          span.material-symbols-outlined.hidden(class='text-[16px]' id='nav-lock-icon-mobile') lock
    nav#bottom-nav(class='md:hidden fixed bottom-0 left-0 w-full z-50 bg-surface/95 backdrop-blur-md border-t border-outline-variant shadow-[0_-2px_10px_rgba(0,0,0,0.06)] safe-bottom')
      div(class='grid grid-cols-4 h-[4.5rem]')
        a.bottom-nav-link(href='#teoria' data-section='teoria' class='flex flex-col items-center justify-center gap-0.5 text-primary px-1')
          span.material-symbols-outlined(class='text-[22px]') menu_book
          span(class='text-[10px] font-label-sm leading-tight text-center') Teoria
        a.bottom-nav-link(href='#questoes' data-section='questoes' class='flex flex-col items-center justify-center gap-0.5 text-on-surface-variant px-1')
          span.material-symbols-outlined(class='text-[22px]') assignment
          span(class='text-[10px] font-label-sm leading-tight text-center') Resolvidas
        a.bottom-nav-link(href='#simulado' data-section='simulado' class='flex flex-col items-center justify-center gap-0.5 text-on-surface-variant px-1')
          span.material-symbols-outlined(class='text-[22px]') quiz
          span(class='text-[10px] font-label-sm leading-tight text-center') Simulado
        a.bottom-nav-link(href='#exercicios' data-section='exercicios' class='flex flex-col items-center justify-center gap-0.5 text-on-surface-variant px-1 relative')
          span.material-symbols-outlined(class='text-[22px]') lock_open
          span(class='text-[10px] font-label-sm leading-tight text-center') Quadro
          span.material-symbols-outlined.hidden.absolute.top-1.right-1(class='text-[12px] text-tertiary' id='bottom-lock-icon') lock
    block content
    footer(class='w-full py-stack-md md:py-stack-lg px-4 md:px-margin-desktop flex flex-col md:flex-row justify-between items-center gap-stack-md md:gap-gutter bg-surface-container-low text-secondary mt-stack-lg text-center md:text-left')
      .text-label-md.font-label-md.font-black.text-on-surface ProbabilidadeEdu
      .text-label-sm.font-label-sm.text-on-surface-variant © 2026 ProbabilidadeEdu. Todos os direitos reservados.
    script(src='/javascripts/probabilidade/questionBank.js')
    script(src='/javascripts/probabilidade/simulado.js')
    block scripts
